{
  "name": "typewise-extension",
  "version": "1.0.0",
  "description": "Smart text expansion extension with GitHub Gist sync",
  "main": "src/background/background.ts",
  "scripts": {
    "dev": "webpack --mode development --watch",
    "build": "webpack --mode production",
    "build:chrome": "cross-env TARGET=chrome webpack --mode production",
    "build:firefox": "cross-env TARGET=firefox webpack --mode production",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.{ts,tsx}",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "package:chrome": "npm run build:chrome && cd dist/chrome && zip -r ../../typewise-chrome.zip .",
    "package:firefox": "npm run build:firefox && cd dist/firefox && zip -r ../../typewise-firefox.zip ."
  },
  "keywords": [
    "browser-extension",
    "text-expansion",
    "productivity",
    "github-gist",
    "typescript"
  ],
  "author": "Rahul Pal",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.251",
    "@types/crypto-js": "^4.1.3",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "mini-css-extract-plugin": "^2.7.6",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.10.0"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "dompurify": "^3.3.3",
    "idb": "^7.1.1"
  }
}
