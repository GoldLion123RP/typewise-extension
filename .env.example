# TypeWise Environment Variables
# Copy this file to .env.local and fill in your values

# Optional: GitHub OAuth public client ID (needed only for GitHub Gist sync)
# Get this from: https://github.com/settings/developers
# Do NOT add a GitHub client secret to this project.
GITHUB_CLIENT_ID=your_client_id_here

# No client secret is used in this browser extension runtime.

# Development
NODE_ENV=development
